{
  "name": "studycircle-workspace",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "dev": "npx concurrently \"npm run dev:server\" \"npm run dev:client\""
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
